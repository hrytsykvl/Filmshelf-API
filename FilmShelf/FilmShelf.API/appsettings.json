{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "http://localhost:8080",
    "Audience": "http://localhost:4200",
    "ExpirationMinutes": 1,
    "RefreshTokenExpirationMinutes": 60
  },
  "MailJet": {
    "FromEmail": "gricikvlad@gmail.com",
    "FromName": "FilmShelf"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Debug",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/applog-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ],
    "Properties": {
      "ApplicationName": "FilmShelf"
    }
  },
  "TmdbSettings": {
    "BaseUrl": "https://api.themoviedb.org/3",
    "SortBy": "vote_count.desc",
    "PagesToFetch": 3,
    "IntervalInHours": 24,
    "ScheduledTime": "08:00",
    "TotalPages": "500",
    "Images": {
      "BaseUrl": "https://image.tmdb.org/t/p/",
      "PosterSizes": [
        "w92",
        "w154",
        "w185",
        "w342",
        "w500",
        "w780",
        "original"
      ],
      "DefaultPosterSize": "w500"
    },
    "NumberOfActors": "10",
    "CrewJob": "Director"
  }
}
