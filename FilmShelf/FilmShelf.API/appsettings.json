{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "http://localhost:8080",
    "Audience": "http://localhost:4200",
    "ExpirationMinutes": 240,
    "RefreshTokenExpirationHours": 24
  },
  "Watchlist": {
    "DefaultName": "My Watchlist"
  },
  "MailJet": {
    "FromEmail": "gricikvlad@gmail.com",
    "FromName": "FilmShelf"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Debug",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/applog-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ],
    "Properties": {
      "ApplicationName": "FilmShelf"
    }
  },
  "TmdbSettings": {
    "BaseUrl": "https://api.themoviedb.org/3",
    "SortBy": "vote_count.desc",
    "PagesToFetch": 3,
    "IntervalInHours": 24,
    "ScheduledTime": "08:00",
    "TotalPages": "500",
    "PopularMoviesToFetch": 3,
    "Images": {
      "BaseUrl": "https://image.tmdb.org/t/p/",
      "PosterSizes": [
        "w92",
        "w154",
        "w185",
        "w342",
        "w500",
        "w780",
        "original"
      ],
      "DefaultPosterSize": "w500"
    },
    "NumberOfActors": "10",
    "CrewJob": "Director"
  },
  "Notification": {
    "DelayInMinutes": 1,
    "NotificationHour": 8,
    "NotificationIntervalDays": 1
  },
  "Claude": {
    "Model": "claude-sonnet-4-6",
    "MaxTokens": 6000
  },
  "Llama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3.2"
  },
  "AzureOpenAi": {
    "Endpoint": "https://filmshelf-openai.openai.azure.com/",
    "DeploymentName": "filmshelf-embeddings"
  },
  "AzureSearch": {
    "Endpoint": "https://filmshelf-ai-search.search.windows.net",
    "IndexName": "movies",
    "VectorDimensions": 1536
  }
}
